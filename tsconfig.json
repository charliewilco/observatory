{
  "compilerOptions": {
    "outDir": "dist",
    "module": "esnext",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "sourceMap": true,
    "allowJs": false,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "bundler",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
