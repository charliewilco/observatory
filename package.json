{
  "name": "@charliewilco/observatory",
  "license": "Unlicense",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "prepack": "npm run build",
    "clean": "rm -rf dist coverage",
    "prebuild": "rm -rf dist",
    "build": "npm run build:js && npm run build:types",
    "build:js": "rolldown -c",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "rolldown -c --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-include=dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "rolldown": "^1.0.3",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "printWidth": 95,
    "singleQuote": false,
    "semi": true,
    "bracketSpacing": true
  }
}
